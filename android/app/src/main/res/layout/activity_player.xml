<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/native_player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false" />

    <!-- Status / Loading Overlay -->
    <TextView
        android:id="@+id/tv_status_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="60dp"
        android:background="#88000000"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:visibility="gone"
        android:textStyle="bold" />

    <!-- Progress Bar (Sadece VOD için) -->
    <SeekBar
        android:id="@+id/player_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="110dp"
        android:layout_marginHorizontal="40dp"
        android:progressTint="#FF5252"
        android:thumbTint="#FF5252"
        android:visibility="gone" />

    <!-- Kanal Bilgi Paneli -->
    <LinearLayout
        android:id="@+id/channel_info_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="40dp"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
            <ImageView
                android:id="@+id/iv_favorite"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:src="@android:drawable/btn_star_big_off"
                android:visibility="visible" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_time_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BBBBBB"
            android:textSize="16sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Kumanda Rehberi (OSD Help) -->
    <LinearLayout
        android:id="@+id/key_guide_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#AA000000"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_subtitles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Altyazı"
            android:textColor="#FF5252"
            android:textSize="14sp"
            android:layout_marginEnd="20dp"
            android:textStyle="bold"
            android:padding="10dp" />

        <TextView
            android:id="@+id/btn_audio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Ses"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:layout_marginEnd="20dp"
            android:textStyle="bold"
            android:padding="10dp" />

        <TextView
            android:id="@+id/btn_quality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Kalite"
            android:textColor="#FFEB3B"
            android:textSize="14sp"
            android:layout_marginEnd="20dp"
            android:textStyle="bold"
            android:padding="10dp" />

        <TextView
            android:id="@+id/btn_aspect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Oran"
            android:textColor="#2196F3"
            android:textSize="14sp"
            android:layout_marginEnd="20dp"
            android:textStyle="bold"
            android:padding="10dp" />

        <TextView
            android:id="@+id/btn_favorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[0] Favori"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="10dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#44FFFFFF"
            android:layout_marginHorizontal="10dp" />

        <TextView
            android:id="@+id/tv_guide_nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↕ Kanal Değiştir"
            android:textColor="#BBBBBB"
            android:textSize="13sp"
            android:layout_marginEnd="15dp" />

        <TextView
            android:id="@+id/tv_guide_seek"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↔ İleri/Geri"
            android:textColor="#BBBBBB"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Ses Barı -->
    <LinearLayout
        android:id="@+id/volume_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="20dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tv_volume_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="#FF5252"
            android:textSize="30sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Durdurulduğunda Çıkan Bilgi Paneli -->
    <LinearLayout
        android:id="@+id/pause_info_layout"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="40dp"
        android:background="#DD000000"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_pause_poster"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="#222222"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_pause_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <TextView
                android:id="@+id/tv_pause_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#BBBBBB"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_pause_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFEB3B"
                android:textSize="14sp"
                android:layout_marginStart="16dp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_pause_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#DDDDDD"
            android:textSize="13sp"
            android:layout_marginTop="10dp"
            android:maxLines="6"
            android:ellipsize="end"
            android:lineSpacingExtra="4dp" />
    </LinearLayout>

</FrameLayout>
